{
    "manifest_version": 3,
    "name": "ChatGPT Question Log",
    "version": "1.0.2",
    "description": "A collection of questions asked within a chat session in ChatGPT arranged in a navigational table.",
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/c/*",
                "https://chatgpt.com/g/*"
            ],
            "exclude_globs": [
                "https://chatgpt.com/g/*/project"
            ],
            "css": [
                "contentStyles.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}